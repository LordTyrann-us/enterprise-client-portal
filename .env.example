# =========================================
# Enterprise Client Portal - Environment
# =========================================

# ------------------------
# Application
# ------------------------
APP_NAME=Enterprise Client Portal
ENV=development

# ------------------------
# Backend (FastAPI)
# ------------------------
DATABASE_URL=postgresql+psycopg://clientportal:clientportal@db:5432/clientportal
JWT_SECRET=change-me-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------
# PostgreSQL
# ------------------------
POSTGRES_DB=clientportal
POSTGRES_USER=clientportal
POSTGRES_PASSWORD=clientportal

# ------------------------
# Notes
# ------------------------
# - In Docker, the database host is "db"
# - Do NOT use localhost inside containers
# - Change JWT_SECRET in production
